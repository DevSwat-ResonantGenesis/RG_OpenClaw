# ============================================
# RG OpenClaw — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Platform Service URLs ===
# For Docker deployment (default — these work inside docker-compose)
AGENT_ENGINE_URL=http://agent_engine_service:8000
AUTH_SERVICE_URL=http://auth_service:8000
MEMORY_SERVICE_URL=http://memory_service:8000

# For standalone local use, uncomment and use the public gateway:
# AGENT_ENGINE_URL=https://dev-swat.com/agents
# AUTH_SERVICE_URL=https://dev-swat.com/auth
# MEMORY_SERVICE_URL=https://dev-swat.com/memory

# === OpenClaw Gateway (WebSocket bridge) ===
OPENCLAW_GATEWAY_URL=ws://openclaw_gateway:18789
OPENCLAW_GATEWAY_HTTP_URL=http://openclaw_gateway:18789
OPENCLAW_GATEWAY_TOKEN=

# === Platform Identity ===
PLATFORM_DOMAIN=dev-swat.com

# === Service Auth ===
# Only needed for server-side deployment; leave empty for local use
INTERNAL_SERVICE_KEY=

# === Service Toggle ===
OPENCLAW_SERVICE_ENABLED=true
